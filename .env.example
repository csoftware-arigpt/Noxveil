# Copy this file to .env and replace the placeholder secrets before first run.
# Examples:
#   openssl rand -hex 32   -> JWT_SECRET_KEY
#   openssl rand -hex 24   -> AGENT_AUTH_TOKEN

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
AGENT_AUTH_TOKEN=replace-with-openssl-rand-hex-24
INITIAL_ADMIN_PASSWORD=change-me-now

C2_PORT=1324
ENABLE_TUNNEL=true

DATABASE_URL=sqlite+aiosqlite:///./data/c2.db
VAULT_MASTER_KEY=

CORS_ALLOW_ORIGINS=
TRUSTED_PROXY_IPS=127.0.0.1,::1
TOTP_ISSUER=Noxveil

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AGENT_TOKEN_EXPIRE_DAYS=30
STAGER_TOKEN_EXPIRE_MINUTES=15

C2_URL=https://your-tunnel.trycloudflare.com
C2_CALLBACK_INTERVAL=5
C2_JITTER=2
C2_AUTH_TOKEN=replace-with-bootstrap-token-for-local-agent-tests
C2_CA_BUNDLE=
C2_CERT_SHA256=
C2_INSECURE_TLS=false
